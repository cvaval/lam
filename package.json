{
  "name": "lam-veritab",
  "version": "1.0.0",
  "private": true,
  "description": "Lam Veritab — plateforme SaaS trilingue (FR/EN/HT) de recherche juridique haïtienne. Le fruit du savoir.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:2fa": "tsx scripts/smoke-2fa.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "seed:themes": "tsx scripts/seed-themes.ts",
    "themes:tree": "tsx scripts/themes-tree.ts",
    "db:reset": "tsx scripts/guard-local-db.ts && prisma db push --force-reset && tsx prisma/seed.ts",
    "import:index": "tsx scripts/import-moniteur.ts",
    "search:reindex": "tsx scripts/reindex.ts",
    "setup:opensearch": "bash scripts/setup-opensearch.sh",
    "setup:opensearch:revert": "bash scripts/setup-opensearch.sh --revert",
    "setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:import": "tsx scripts/import-db.ts",
    "db:export": "tsx scripts/export-db.ts",
    "db:rls": "tsx scripts/enable-rls.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/genai": "^2.8.0",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.4.1",
    "bcryptjs": "^2.4.3",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "next": "14.2.15",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@opensearch-project/opensearch": "^2.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.18"
  }
}
