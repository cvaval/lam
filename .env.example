# ───────────────────────────────────────────────────────────────────────────
# Lam Veritab — variables d'environnement (copier vers .env)
# ───────────────────────────────────────────────────────────────────────────

# Base de données
#   Dev (par défaut, zéro infra) : SQLite local
DATABASE_URL="file:./dev.db"
#   Production recommandée : PostgreSQL
# DATABASE_URL="postgresql://user:pass@localhost:5432/lam?schema=public"

# Secrets de session / cookies signés (générer : openssl rand -hex 32)
SESSION_SECRET="dev-only-change-me-please-0000000000000000000000000000000000000000"
TRUSTED_DEVICE_SECRET="dev-only-change-me-too-1111111111111111111111111111111111111111"

# Émetteur TOTP affiché dans l'app d'authentification
TOTP_ISSUER="Lam Veritab"

# ── Recherche (§09) ──
# fts       : moteur intégré (Prisma/SQL) — démarre sans aucune infrastructure
# opensearch: OpenSearch/Elasticsearch — analyseur FR + synonymie EN→FR + surlignage
SEARCH_PROVIDER="fts"
OPENSEARCH_NODE="https://localhost:9200"
OPENSEARCH_USERNAME="admin"
OPENSEARCH_PASSWORD="admin"
OPENSEARCH_INSECURE="true"

# ── Paiement (§09 — double rail) ──
# Laisser vide en dev : les paliers sont simulés.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
MONCASH_CLIENT_ID=""
MONCASH_CLIENT_SECRET=""
NATCASH_MERCHANT_ID=""

# ── IA (vision PDF) : extraction des titres au téléversement, OCR des scans, et
#    reproduction des tableaux & couleurs (scripts/extract-tables.ts).
# Sans clé : repli heuristique (regex) pour l'analyse ; OCR et tableaux indisponibles.
# La plateforme reste fonctionnelle. Renseigner une clé dans .env active ces fonctions.
#
# Deux fournisseurs au choix :
#   LV_AI_PROVIDER=anthropic (défaut) — ANTHROPIC_API_KEY requis
#   LV_AI_PROVIDER=gemini             — GEMINI_API_KEY requis (tier GRATUIT disponible
#                                       sur aistudio.google.com ; gemini-2.0-flash)
LV_AI_PROVIDER=""
ANTHROPIC_API_KEY=""
# Clé Google Gemini (aistudio.google.com → "Get API key" — gratuit)
GEMINI_API_KEY=""
# Modèle (défaut selon fournisseur : claude-opus-4-8 / gemini-2.0-flash)
LV_AI_MODEL=""

# E-mail transactionnel (2FA repli, bienvenue bilingue). Vide = mode console.
SMTP_URL=""
MAIL_FROM="Lam <no-reply@lam.ht>"

# URL publique de base
NEXT_PUBLIC_APP_URL="http://localhost:3000"
